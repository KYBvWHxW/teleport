#!/usr/bin/env python3

# Mock tctl binary for teleport-access-review evals. Returns fixtures from this
# directory based on the access-review --query, instead of hitting a real
# cluster. Models a healthy cluster with Access Graph and activity available;
# the per-state failures (endpoint absent, activity unavailable) have their own
# mock variants alongside this one.

import os, sys

dir = os.path.dirname(os.path.abspath(__file__))
args = sys.argv[1:]


def read(filename):
    with open(os.path.join(dir, filename)) as f:
        print(f.read(), end="")


def query():
    for i, a in enumerate(args):
        if a == "--query" and i + 1 < len(args):
            return args[i + 1]
        if a.startswith("--query="):
            return a.split("=", 1)[1]
    return ""


if args[:1] == ["status"]:
    read("tsh-status.txt")
elif args[:1] == ["access-review"]:
    if "--help" in args:
        print("usage: tctl access-review --query=QUERY [<flags>]\n")
        print("Review which identities can access which resources.")
    else:
        # Dispatch on the query so a discovery (ILIKE) query and the scoped
        # query for the same scenario resolve to one dataset.
        q = query().lower()
        if "payments-db" in q:
            read("injection.json")
        elif "staging-db" in q:
            read("multi-grantor.json")
        elif "alice" in q:
            read("alice-standing.json")
        elif "prod-db" in q:
            read("who-can-access.json")
        else:
            print('{"identities": []}')
else:
    print(f"mock-tctl: unrecognized command: {' '.join(args)}", file=sys.stderr)
    sys.exit(1)
